MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=doremi_eng

# AI Image Generation (Optional)
# Uncomment and add your API key to enable AI image generation for exercises
# If not configured, the system will use local images or fallback to placeholders
OPENAI_API_KEY=sk-your-openai-api-key-here

# 9Router AI API (Required for Vocabulary Lookup)
# Used for auto-filling vocabulary data (meaning, phonetic, examples)
# Get your API key from https://9router.com
NINEROUTER_API_KEY=your-9router-api-key-here

# YouTube Data API v3 (Required for Video Learning Feature)
# Used to fetch video information from YouTube playlists
# Get your API key from https://console.cloud.google.com/
YOUTUBE_API_KEY=your-youtube-api-key-here

# Google Drive API (Required for User Registration Data Backup)
# Used to automatically save user registration data to Google Drive
# Place your credentials.json file in the project root directory
# Get your credentials from https://console.cloud.google.com/
# Note: credentials.json should NOT be committed to version control

# Ollama API (Optional - for Video Learning AI features)
# If running Ollama locally, use: http://localhost:11434
# If using Cloudflare Tunnel for production, use the tunnel URL
# Example: https://abc-def-ghi.trycloudflare.com
# OLLAMA_BASE_URL=http://localhost:11434

